# ShiftIQ — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave blank to use SQLite (finance.db)
# Production: set to your PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/shiftiq
DATABASE_URL=

# ── API ───────────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on (default: 8000)
PORT=8000

# ── Security ──────────────────────────────────────────────────────────────────
# Used for signing JWT tokens in Phase 2 (Auth).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
